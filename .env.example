# ── AvizSazeh — Production Environment ──────────────────────────────
# Canonical site origin (no trailing slash). Used for metadata, sitemap, OG, hreflang.
NEXT_PUBLIC_SITE_URL=https://avizsazeh.ir

# ── Odoo CRM integration ────────────────────────────────────────────
# RFQ submissions are pushed to Odoo as CRM leads via POST {ODOO_BASE_URL}/api/crm/leads
# with an Authorization: Bearer ${ODOO_API_TOKEN} header.
# If ODOO_BASE_URL is unset, the RFQ engine runs in log-only mode.
ODOO_BASE_URL=https://odoo.sipanel.ir
ODOO_API_TOKEN=REPLACE_ME

# ── Analytics (optional) ────────────────────────────────────────────
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=avizsazeh.ir
