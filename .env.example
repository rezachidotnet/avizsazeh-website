# ── AvizSazeh — Production Environment ──────────────────────────────
# Canonical site origin (no trailing slash). Used for metadata, sitemap, OG, hreflang.
NEXT_PUBLIC_SITE_URL=https://avizsazeh.ir

# ── RFQ Engine notifications (optional) ─────────────────────────────
# If set, RFQ submissions are emailed via an SMTP relay / transactional API.
# Leave unset to run the RFQ engine in log-only mode (submissions logged + acknowledged).
RFQ_NOTIFY_EMAIL=info@avizsazeh.ir
# RESEND_API_KEY=
# SMTP_URL=

# ── Analytics (optional) ────────────────────────────────────────────
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=avizsazeh.ir
