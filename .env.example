# ── AvizSazeh — Production Environment ──────────────────────────────
# Canonical site origin (no trailing slash). Used for metadata, sitemap, OG, hreflang.
# Production serves on the www host (apex avizsazeh.ir 301-redirects to www).
NEXT_PUBLIC_SITE_URL=https://www.avizsazeh.ir

# ── Odoo CRM integration (JSON-RPC) ─────────────────────────────────
# RFQ submissions create a crm.lead in Odoo via JSON-RPC (common.login +
# object.execute_kw), matching the proven SIPANELCO integration.
# If these are unset, the RFQ engine runs in log-only mode (still returns a result).
ODOO_URL=https://odoo.example.ir
ODOO_DB=your_db
ODOO_USERNAME=your_odoo_user
ODOO_PASSWORD=__set_in_env_only__
# Optional CRM routing:
# ODOO_CRM_TEAM_ID=            # sales team id for website leads (e.g. sale_aviz)
# ODOO_CRM_SOURCE_ID=
# Assign website leads to a dedicated salesperson. Set the login (resolved to a
# res.users id at runtime) or a numeric id directly. If the user doesn't exist
# yet, leads are still created — just left to the team's default assignment.
# ODOO_SALESPERSON_LOGIN=website@avizsazeh.ir
# ODOO_SALESPERSON_ID=
# Write x_ custom fields to crm.lead (x_buyer_role, x_ceiling_system, …).
# Leave unset/false until the matching Studio fields exist in Odoo — otherwise
# lead creation fails. All RFQ data is always included in the lead description
# regardless of this flag.
# ODOO_USE_CUSTOM_FIELDS=true

# ── RFQ backup ──────────────────────────────────────────────────────
# When Odoo is unavailable, the full lead is logged as a recoverable backup.
# Set this to the inbox that should receive RFQ leads (wiring an SMTP/webhook
# sender is a follow-up — the address is currently logged for reference).
# RFQ_NOTIFICATION_EMAIL=info@avizsazeh.ir

# ── Analytics (optional, all client-side / NEXT_PUBLIC_) ────────────
# Any combination may be set; unset providers simply don't load. The site
# works identically with none configured.
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=avizsazeh.ir
# NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx
# Set to 'true' to console.debug every tracked event (local QA only).
# NEXT_PUBLIC_ANALYTICS_DEBUG=false
